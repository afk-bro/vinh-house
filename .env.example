# .env.example — copy to .env.local and fill in
# Public site origin (no trailing slash) — used for SEO canonical/hreflang,
# OpenGraph image URLs, sitemap.xml and robots.txt. MUST be the real production
# domain or link previews (WhatsApp/Facebook) and sitemap URLs break.
NEXT_PUBLIC_SITE_URL=https://example.com
# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated list of admin emails allowed into /admin
ADMIN_EMAILS=
